# HTTP server
SERVER_ADDR=:8080

# PostgreSQL (matches docker-compose.yml)
SERVER_NAME=localhost
SERVER_PORT=5432
DATABASE_NAME=lab-golang
USER_DB=root
PASSWORD_DB=root
DB_SSLMODE=disable

# Security — replace with a long random string in any real environment
JWT_SECRET=dev-only-insecure-secret-change-me

# Toggle JWT auth on the api-gateway (true = enforce tokens, false = open)
AUTH_ENABLED=false

# CORS: comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:3000
