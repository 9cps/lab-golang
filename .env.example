# HTTP server
SERVER_ADDR=:8080

# PostgreSQL
SERVER_NAME=localhost
SERVER_PORT=5432
DATABASE_NAME=lab-golang
USER_DB=changeme
PASSWORD_DB=changeme
DB_SSLMODE=disable

# Security
JWT_SECRET=replace-with-a-long-random-string

# Toggle JWT auth on the api-gateway. true (default) enforces tokens on
# /expenses; set to false to disable auth for local development.
AUTH_ENABLED=true

# CORS: comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:3000
